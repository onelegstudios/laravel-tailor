includes:
    - phpstan-baseline.neon

parameters:
    level: 5
    paths:
        - bin
        - config
        - database
        - src
        - tests
    tmpDir: build/phpstan
    ignoreErrors:
        -
            message: '#^Call to an undefined method Pest\\PendingCalls\\TestCall::expect\(\)\.$#'
            path: tests/ArchTest.php