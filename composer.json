{
    "name": "onelegstudios/laravel-tailor",
    "description": "Tailor the Laravel Livewire starter kit to your taste. Run a single interactive command to swap the kit's icon set, apply optional tweaks, and keep everything consistent — no hand-editing Blade views or hunting down icon names.",
    "keywords": [
        "laravel",
        "livewire",
        "flux",
        "fluxui",
        "starter-kit",
        "icons",
        "heroicons",
        "lucide",
        "scaffolding",
        "dev"
    ],
    "homepage": "https://github.com/onelegstudios/laravel-tailor",
    "license": "MIT",
    "authors": [
        {
            "name": "Henrik Persson",
            "email": "henrik.persson@onelegstudios.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "spatie/laravel-package-tools": "^1.16",
        "illuminate/contracts": "^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.14",
        "livewire/flux": "^2.0",
        "livewire/flux-pro": "*",
        "livewire/livewire": "^4.0",
        "nunomaduro/collision": "^8.8",
        "orchestra/testbench": "^11.0.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Onelegstudios\\Tailor\\": "src/",
            "Onelegstudios\\Tailor\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Onelegstudios\\Tailor\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "lint": [
            "pint --parallel"
        ],
        "lint:check": [
            "pint --parallel --test"
        ],
        "ci:check": [
            "Composer\\Config::disableProcessTimeout",
            "@test"
        ],
        "types:check": [
            "phpstan analyse --memory-limit=2G"
        ],
        "test": [
            "@lint:check",
            "@types:check",
            "pest --parallel"
        ],
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Onelegstudios\\Tailor\\TailorServiceProvider"
            ],
            "aliases": {
                "Tailor": "Onelegstudios\\Tailor\\Facades\\Tailor"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "name": "flux-pro",
            "type": "composer",
            "url": "https://composer.fluxui.dev"
        }
    ]
}
