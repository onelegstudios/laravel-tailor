#!/usr/bin/env php
<?php

/*
 * Dev-only script: scan for the icon names the app needs and record them in
 * config/tailor.php under the Lucide kit's icons key
 * (settings.kits.lucide.icons), split into sub-arrays by source.
 *
 * Tailor needs to know every icon that must be re-mapped when the user switches
 * UI kit. That icons key has two groups:
 *
 *   starter-kit          — icons the app's own views use (scanned from
 *                          tests/Fixtures):
 *       heroicons        — Flux's default Heroicons.
 *       lucide           — names the starter kit ships as local overrides (blade
 *                          files under resources/views/flux/icon/, from lucide.dev).
 *   flux                 — icons Flux's own bundled components render internally,
 *                          split by which package ships the component that
 *                          references them. Each sub-group excludes anything
 *                          already in starter-kit (heroicons or lucide), so no icon
 *                          is duplicated across the two groups:
 *       free             — referenced by a component in vendor/livewire/flux (e.g.
 *                          error's `exclamation-triangle`). Always downloaded.
 *       pro              — referenced *only* by a component in
 *                          vendor/livewire/flux-pro (e.g. the date-picker's
 *                          `calendar`), and so excluding anything already in free.
 *                          LucideKit skips this group when flux-pro isn't
 *                          installed — see the note on Flux Pro below.
 *       animated         — Flux's built-in animated pseudo-icons (e.g. the
 *                          `loading` spinner); see ANIMATED_ICONS.
 *
 * Values: heroicons, flux.free and flux.pro start empty (their Lucide equivalent
 * is filled in later). lucide and animated map to themselves (correct in any kit).
 *
 * HeroKit (settings.kits.hero.icons) is kept in sync too: its key set mirrors the
 * starter-kit.lucide overrides above, but each key maps to a Heroicon rather than
 * itself. Only the *keys* are managed here — added when new overrides appear,
 * removed with --prune — while the hand-picked Heroicon values are left alone
 * (new keys seed empty, to fill in by hand).
 *
 * Icons are referenced four ways in the Flux markup:
 *
 *   <flux:icon.chevron-down />          (component dot syntax)
 *   <flux:icon name="loading" />        (component name attr)
 *   <flux:button icon="trash" />        (icon / icon:trailing / icon:leading attr)
 *   @props(['icon' => 'document'])      (component's default icon, e.g. file-item)
 *
 * Limitation — hardcoded inline SVGs: a few Flux components draw their glyph as a
 * raw <svg><path> embedded in the blade rather than via the icon system above
 * (e.g. sidebar/collapse's panel toggle, toast's close, the Pro editor toolbar).
 * These have no icon name to scan and no flux/icon/<name>.blade.php hook to
 * override, so they can't be captured here or remapped through the icons key.
 * Re-skinning them would require overriding the whole component blade — out of
 * scope for this name-based scanner.
 *
 * Note on Flux Pro: Pro adds components, not an icon set — but those components
 * reference icons the free package's never do, and an app without Pro has no way
 * to render them. So the two packages are scanned separately and recorded as
 * flux.free and flux.pro, letting LucideKit skip the Pro group when flux-pro
 * isn't installed rather than downloading six glyphs the app can't use.
 *
 * Both are pulled in as dev dependencies (see composer.json require-dev); the Pro
 * repository requires license auth, read from a local/global composer auth.json —
 * never committed. A Flux package missing from vendor is skipped, and its group is
 * then left untouched rather than warned about or pruned: without the source there
 * is no way to tell "removed upstream" from "not installed here", and pruning on
 * that guess would silently drop working mappings from the shipped config.
 *
 * Existing entries (and any values already filled in) keep their order. By
 * default the script is append-only: newly discovered names are added, and names
 * no longer found anywhere are reported as a warning but left in place (so manual
 * mappings survive). Pass --prune to actually remove those stale entries.
 *
 * Usage (run with -h/--help for details):
 *   bin/scan-icons               # add new icons; warn about stale ones
 *   bin/scan-icons -p, --prune   # also remove icons no longer found
 *   bin/scan-icons -c, --check   # report missing icons, write nothing (exit 1)
 *   bin/scan-icons -h, --help    # show help
 */

// Flux's built-in animated pseudo-icons: not Heroicons, and they stay put across
// kits. `loading` is the only one, and both Flux packages reference it — so this
// group needs no free/pro split and is always downloaded. Extend if Flux adds one.
const ANIMATED_ICONS = ['loading'];

$root = dirname(__DIR__);
$fixturesDir = $root.'/tests/Fixtures';
$configFile = $root.'/config/tailor.php';

$flags = array_slice($argv, 1);
$hasFlag = fn (string ...$names): bool => array_intersect($names, $flags) !== [];

$help = $hasFlag('--help', '-h');
$check = $hasFlag('--check', '-c');
$prune = $hasFlag('--prune', '-p');

if ($help) {
    echo <<<'HELP'
        scan-icons — scan the starter-kit fixtures and Flux's components for the
        icon names the app uses, and record them in config/tailor.php under the
        Lucide kit (grouped under settings.kits.lucide.icons: starter-kit and flux).

        Usage:
          bin/scan-icons [options]

        Options:
          -c, --check   Report icons missing from the config and exit 1 without writing.
                        For tests/CI; makes no changes.
          -p, --prune   Remove config entries for icons no longer found in any source.
                        Without it, stale icons are kept and reported as a warning.
          -h, --help    Show this help and exit.

        With no options, newly found icons are added and stale ones are only warned about.

        HELP;
    exit(0);
}

if (! is_dir($fixturesDir)) {
    fwrite(STDERR, "Fixtures directory not found: {$fixturesDir}\n");
    fwrite(STDERR, "Run bin/download-fixtures first.\n");
    exit(1);
}

/**
 * Collect every text file under a directory that may contain markup.
 *
 * @return list<string>
 */
function collectFiles(string $dir): array
{
    $allowed = ['blade.php', 'php', 'vue', 'js', 'ts', 'html', 'antlers.html'];

    $files = [];
    $iterator = new RecursiveIteratorIterator(
        new RecursiveDirectoryIterator($dir, FilesystemIterator::SKIP_DOTS)
    );

    foreach ($iterator as $file) {
        $name = $file->getFilename();
        foreach ($allowed as $ext) {
            if (str_ends_with($name, '.'.$ext)) {
                // Normalise to forward slashes so downstream path matching (the
                // /flux/icon/ checks) works on Windows, where the iterator yields
                // backslash-separated paths.
                $files[] = str_replace('\\', '/', $file->getPathname());
                break;
            }
        }
    }

    // Sort for a deterministic scan order across platforms — RecursiveDirectory-
    // Iterator yields entries in filesystem-dependent order, which would otherwise
    // make the generated icon order (and the config it produces) differ per OS.
    sort($files);

    return $files;
}

/**
 * Scan files for icon names referenced via either Flux syntax. Skips icon-
 * definition files (the flux/icon/ dirs), which declare icons rather than use
 * them.
 *
 * @param  list<string>  $files
 * @return array<string, true>
 */
function scanIcons(array $files): array
{
    $found = [];
    foreach ($files as $file) {
        if (str_contains($file, '/flux/icon/')) {
            continue;
        }

        $contents = file_get_contents($file);

        if ($contents === false) {
            continue;
        }

        // <flux:icon.chevron-down />
        if (preg_match_all('/flux:icon\.([a-z0-9-]+)/', $contents, $m) > 0) {
            foreach ($m[1] as $name) {
                $found[$name] = true;
            }
        }

        // <flux:icon name="loading" /> (name attr; dynamic "{{ $icon }}" excluded).
        // Quote group is backreferenced so single- and double-quoted attrs match.
        if (preg_match_all('/<flux:icon\b[^>]*\bname=([\'"])([a-z0-9-]+)\1/', $contents, $m) > 0) {
            foreach ($m[2] as $name) {
                $found[$name] = true;
            }
        }

        // icon="trash"  icon:trailing="chevron-down"  icon:leading="plus"
        // (deliberately excludes icon:variant="outline" and other attributes).
        // Lookbehind rejects a leading name char so data-icon="x" doesn't match.
        if (preg_match_all('/(?<![\w-])icon(?::(?:trailing|leading))?=([\'"])([a-z0-9-]+)\1/', $contents, $m) > 0) {
            foreach ($m[2] as $name) {
                $found[$name] = true;
            }
        }

        // @props(['icon' => 'document']) — a component's hardcoded default icon.
        // Keyed on exactly 'icon', so 'iconVariant' => 'mini' is left out.
        if (preg_match_all('/[\'"]icon[\'"]\s*=>\s*[\'"]([a-z0-9-]+)[\'"]/', $contents, $m) > 0) {
            foreach ($m[1] as $name) {
                $found[$name] = true;
            }
        }
    }

    return $found;
}

// Source 1: the app's own views.
$fixtureFiles = collectFiles($fixturesDir);

// Source 2: Flux's bundled component blades. The two packages are scanned
// separately so each icon can be attributed to the package whose component
// references it; either is skipped if uninstalled.
$fluxRoot = $root.'/vendor/livewire/flux/stubs/resources/views/flux';
$fluxProRoot = $root.'/vendor/livewire/flux-pro/stubs/resources/views/flux';

$freeFiles = is_dir($fluxRoot) ? collectFiles($fluxRoot) : [];
$proFiles = is_dir($fluxProRoot) ? collectFiles($fluxProRoot) : [];

// Whether each package's blades were actually available to scan. When they
// weren't, that group can't tell "removed upstream" from "package not installed",
// so it is never warned about or pruned.
$freeScanned = $freeFiles !== [];
$proScanned = $proFiles !== [];

if (! $freeScanned) {
    fwrite(STDERR, "Note: livewire/flux not installed in vendor; flux.free left unchanged.\n");
}

if (! $proScanned) {
    fwrite(STDERR, "Note: livewire/flux-pro not installed in vendor; flux.pro left unchanged.\n");
}

// Names the starter kit overrides locally with Lucide blade files (its own
// flux/icon/ dir; vendor flux/icon/ holds Flux's bundled icon *definitions*).
$overrides = [];
foreach ($fixtureFiles as $file) {
    if (preg_match('#/flux/icon/([a-z0-9-]+)\.blade\.php$#', $file, $m) === 1) {
        $overrides[$m[1]] = true;
    }
}

$fixtureIcons = array_keys(scanIcons($fixtureFiles));
$freeIcons = array_keys(scanIcons($freeFiles));
$proIcons = array_keys(scanIcons($proFiles));
$allIcons = array_unique(array_merge($fixtureIcons, $freeIcons, $proIcons));

$isOverride = fn (string $name): bool => isset($overrides[$name]);
$isAnimated = fn (string $name): bool => in_array($name, ANIMATED_ICONS, true);

// Classify by source. The starter-kit group is the app's own icons (heroicons +
// lucide overrides). The flux group is the extra icons only Flux's components
// pull in — excluding anything already in starter-kit so no icon is duplicated
// across the two groups. animated is keyed off the name.
$heroicons = array_filter($fixtureIcons, fn (string $name): bool => ! $isOverride($name) && ! $isAnimated($name));
$lucide = array_filter($allIcons, $isOverride);
$animated = array_filter($allIcons, fn (string $name): bool => ! $isOverride($name) && $isAnimated($name));

$starterKitSet = array_flip(array_merge($heroicons, $lucide));
$isFluxOnly = fn (string $name): bool => ! $isAnimated($name) && ! isset($starterKitSet[$name]);

$free = array_filter($freeIcons, $isFluxOnly);

// An icon both packages reference belongs to free: a free-only app renders it, so
// it must survive the Pro group being skipped. That makes pro strictly the icons
// no free component can ask for.
$freeSet = array_flip($freeIcons);
$pro = array_filter(
    $proIcons,
    fn (string $name): bool => $isFluxOnly($name) && ! isset($freeSet[$name])
);

$config = is_file($configFile) ? require $configFile : [];

if (! is_array($config)) {
    fwrite(STDERR, "Expected {$configFile} to return an array.\n");
    exit(1);
}

// Icons are stored as associative arrays keyed by the icon name, with the value
// reserved for its equivalent in the target UI kit (empty for now). They live
// under the Lucide kit's own settings slice; HeroKit's `icons` key is hand-
// maintained and left untouched.
$existingIcons = $config['settings']['kits']['lucide']['icons'] ?? [];

/**
 * Reconcile an existing group with the scanned names. Newly discovered names are
 * appended (seeded with $value); names no longer scanned are reported as stale
 * and removed only when $prune is true. Existing entries — and any values already
 * filled in — keep their order.
 *
 * @param  array<string, string>  $existing
 * @param  list<string>  $scanned
 * @param  callable(string): string  $value
 * @return array{0: array<string, string>, 1: list<string>, 2: list<string>}
 */
function mergeGroup(array $existing, array $scanned, callable $value, bool $prune): array
{
    $existingNames = array_keys($existing);
    $new = array_values(array_diff($scanned, $existingNames));
    $stale = array_values(array_diff($existingNames, $scanned));
    sort($new);
    sort($stale);

    foreach ($new as $name) {
        $existing[$name] = $value($name);
    }

    if ($prune) {
        foreach ($stale as $name) {
            unset($existing[$name]);
        }
    }

    return [$existing, $new, $stale];
}

// Nested groups: [scanned names, value seed, reliable?]. Heroicons, flux.free and
// flux.pro need a Lucide mapping (empty); lucide and animated map to themselves.
// "reliable" marks whether a missing scan means "removed" — false for a flux group
// whose package isn't installed, so it's never warned about/pruned.
$empty = fn (string $name): string => '';
$self = fn (string $name): string => $name;
$groups = [
    'starter-kit' => [
        'heroicons' => [array_values($heroicons), $empty, true],
        'lucide' => [array_values($lucide), $self, true],
    ],
    'flux' => [
        'free' => [array_values($free), $empty, $freeScanned],
        // pro is derived by subtracting free's icons, so an unscanned free
        // package would wrongly widen it — trust it only when both were scanned.
        'pro' => [array_values($pro), $empty, $proScanned && $freeScanned],
        'animated' => [array_values($animated), $self, true],
    ],
];

$merged = [];
$added = [];
$removed = [];
$counts = [];
foreach ($groups as $parent => $children) {
    foreach ($children as $child => [$scanned, $value, $reliable]) {
        $key = "{$parent}.{$child}";
        $existing = $existingIcons[$parent][$child] ?? [];

        if ($reliable) {
            [$merged[$parent][$child], $added[$key], $removed[$key]] = mergeGroup($existing, $scanned, $value, $prune);
        } else {
            // Source unavailable: keep the group exactly as it is.
            [$merged[$parent][$child], $added[$key], $removed[$key]] = [$existing, [], []];
        }

        $counts[] = count($merged[$parent][$child])." {$key}";
    }
}

// HeroKit's icons key (settings.kits.hero.icons) mirrors the *keys* of the
// starter kit's Lucide overrides (settings.kits.lucide.icons.starter-kit.lucide):
// the same icon names, but each mapped to its Heroicon equivalent instead of
// itself. Keep that key set in sync with the overrides — appending new names and,
// with --prune, dropping stale ones — while leaving the hand-picked Heroicon
// values alone (new names seed empty, to be filled in by hand).
$existingHeroIcons = $config['settings']['kits']['hero']['icons'] ?? [];
[$mergedHero, $added['hero.icons'], $removed['hero.icons']] = mergeGroup($existingHeroIcons, array_values($lucide), $empty, $prune);
$counts[] = count($mergedHero).' hero.icons';

$summary = implode(', ', $counts);
$totalNew = array_sum(array_map('count', $added));
$totalStale = array_sum(array_map('count', $removed));

/**
 * Write the per-group name lists to a stream, prefixed by $verb.
 *
 * @param  array<string, list<string>>  $groups
 */
function reportGroups($stream, string $verb, array $groups): void
{
    foreach ($groups as $key => $names) {
        if ($names !== []) {
            fwrite($stream, $verb.' '.count($names).' '.$key.': '.implode(', ', $names)."\n");
        }
    }
}

// Build the would-be file once; both --check and the writer compare it to disk so
// they agree on "out of sync" (new icons, formatting drift, or --prune staleness).
$current = is_file($configFile) ? file_get_contents($configFile) : '';
$contents = buildConfigContents($configFile, $merged, $mergedHero);
$changed = $contents !== $current;

// --check: report drift and exit without writing.
if ($check) {
    if (! $changed) {
        echo "config/tailor.php is up to date ({$summary}).\n";
        exit(0);
    }

    fwrite(STDERR, "config/tailor.php is out of sync:\n");
    reportGroups(STDERR, 'missing', $added);
    if ($prune) {
        reportGroups(STDERR, 'stale', $removed);
    }
    fwrite(STDERR, 'Run bin/scan-icons'.($prune ? ' --prune' : '')." to update it.\n");
    exit(1);
}

// Nothing to change: in append-only mode stale entries stay (warned, not removed).
if (! $changed) {
    if ($totalStale > 0) {
        fwrite(STDERR, "Warning: {$totalStale} icon(s) no longer found in any source (kept):\n");
        reportGroups(STDERR, 'stale', $removed);
        fwrite(STDERR, "Run bin/scan-icons --prune to remove them.\n");
    } else {
        echo "config/tailor.php is up to date ({$summary}).\n";
    }
    exit(0);
}

/**
 * Pretty-print a value as PHP using short-array syntax.
 */
function exportPhp(mixed $value, int $depth): string
{
    if (! is_array($value)) {
        return var_export($value, true);
    }

    if ($value === []) {
        return '[]';
    }

    $pad = str_repeat('    ', $depth + 1);
    $closePad = str_repeat('    ', $depth);
    $isList = array_is_list($value);

    $lines = [];
    foreach ($value as $key => $item) {
        $prefix = $isList ? '' : var_export($key, true).' => ';
        $lines[] = $pad.$prefix.exportPhp($item, $depth + 1).',';
    }

    return "[\n".implode("\n", $lines)."\n".$closePad.']';
}

/**
 * Find the `'<key>' => [ ... ]` span in the config source by matching brackets
 * (ignoring any inside quoted strings), searching from $from. Returns the start
 * offset at the key and the length through the matching close bracket, or null
 * if not found.
 *
 * @return array{0: int, 1: int}|null
 */
function locateKeySpan(string $source, string $key, int $from = 0): ?array
{
    $pattern = '/([\'"])'.preg_quote($key, '/').'\1\s*=>\s*\[/';

    if (preg_match($pattern, $source, $m, PREG_OFFSET_CAPTURE, $from) !== 1) {
        return null;
    }

    $keyStart = $m[0][1];
    $i = $keyStart + strlen($m[0][0]) - 1; // the opening [
    $len = strlen($source);
    $depth = 0;

    for (; $i < $len; $i++) {
        $char = $source[$i];

        if ($char === '\'' || $char === '"') {
            // Skip the string literal so brackets inside it don't count.
            for ($i++; $i < $len; $i++) {
                if ($source[$i] === '\\') {
                    $i++;
                } elseif ($source[$i] === $char) {
                    break;
                }
            }
        } elseif ($char === '[') {
            $depth++;
        } elseif ($char === ']' && --$depth === 0) {
            return [$keyStart, $i - $keyStart + 1];
        }
    }

    return null;
}

/**
 * Locate the Lucide kit's `icons` span. The search is scoped to the `lucide`
 * block so HeroKit's own `icons` key (a sibling under settings.kits) is never
 * matched. Returns absolute [start, length] into $source, or null if absent.
 *
 * @return array{0: int, 1: int}|null
 */
function locateLucideIconsSpan(string $source): ?array
{
    if (($lucide = locateKeySpan($source, 'lucide')) === null) {
        return null;
    }

    $segment = substr($source, $lucide[0], $lucide[1]);

    if (($icons = locateKeySpan($segment, 'icons')) === null) {
        return null;
    }

    return [$lucide[0] + $icons[0], $icons[1]];
}

/**
 * Locate HeroKit's `icons` span, scoped to the `hero` block so the Lucide kit's
 * own `icons` key (a sibling under settings.kits) is never matched. Returns
 * absolute [start, length] into $source, or null if absent.
 *
 * @return array{0: int, 1: int}|null
 */
function locateHeroIconsSpan(string $source): ?array
{
    if (($hero = locateKeySpan($source, 'hero')) === null) {
        return null;
    }

    $segment = substr($source, $hero[0], $hero[1]);

    if (($icons = locateKeySpan($segment, 'icons')) === null) {
        return null;
    }

    return [$hero[0] + $icons[0], $icons[1]];
}

/**
 * Build the would-be config file: the Lucide and Hero kits' icons arrays spliced
 * into the existing file, or — when the Lucide block is absent — the whole
 * settings scaffold inserted (or a minimal stub when no file exists). Aborts on a
 * file that can't be read or has no `return [` array.
 *
 * @param  array<string, mixed>  $merged
 * @param  array<string, string>  $heroIcons
 */
function buildConfigContents(string $configFile, array $merged, array $heroIcons): string
{
    // Both icons keys sit four levels deep (settings > kits > lucide|hero >
    // icons), so their entries are indented to match when spliced in place.
    $iconsBlock = "'icons' => ".exportPhp($merged, 4);
    $heroBlock = "'icons' => ".exportPhp($heroIcons, 4);

    // Scaffold used when there's no Lucide icons block to replace: the full
    // settings tree, printed as a top-level `settings` key (depth 1).
    $scaffold = "'settings' => ".exportPhp([
        'kits' => [
            'hero' => ['icons' => $heroIcons],
            'lucide' => ['icons' => $merged],
        ],
    ], 1);

    if (! is_file($configFile)) {
        return "<?php\n\n// config for Onelegstudios/Tailor\nreturn [\n    {$scaffold},\n];\n";
    }

    $original = file_get_contents($configFile);

    if ($original === false) {
        fwrite(STDERR, "Could not read {$configFile}.\n");
        exit(1);
    }

    if (($lucideSpan = locateLucideIconsSpan($original)) !== null) {
        // Replace each kit's icons array in place. The Hero block may be absent
        // (older config); splice whichever spans exist, from the end of the file
        // backwards so each earlier span's offset stays valid after the edit.
        $edits = [[$lucideSpan, $iconsBlock]];

        if (($heroSpan = locateHeroIconsSpan($original)) !== null) {
            $edits[] = [$heroSpan, $heroBlock];
        }

        usort($edits, fn (array $a, array $b): int => $b[0][0] <=> $a[0][0]);

        $result = $original;
        foreach ($edits as [$span, $block]) {
            $result = substr_replace($result, $block, $span[0], $span[1]);
        }

        return $result;
    }

    if (preg_match('/\breturn\s*\[/', $original, $m, PREG_OFFSET_CAPTURE) === 1) {
        // No Lucide icons block yet: insert the settings scaffold at the top of
        // the returned array.
        $at = $m[0][1] + strlen($m[0][0]);

        return substr_replace($original, "\n    {$scaffold},", $at, 0);
    }

    fwrite(STDERR, "Could not find a 'return [' array in {$configFile} to update.\n");
    exit(1);
}

// Write atomically: a temp file in the same dir, then rename into place, so an
// interrupted or failed write can never leave config/tailor.php truncated.
$tmpFile = $configFile.'.tmp';
if (file_put_contents($tmpFile, $contents) === false || ! rename($tmpFile, $configFile)) {
    @unlink($tmpFile);
    fwrite(STDERR, "Failed to write {$configFile}.\n");
    exit(1);
}

reportGroups(STDOUT, 'added', $added);

if ($prune) {
    reportGroups(STDOUT, 'removed', $removed);
} elseif ($totalStale > 0) {
    fwrite(STDERR, "Warning: {$totalStale} icon(s) no longer found in any source (kept):\n");
    reportGroups(STDERR, 'stale', $removed);
    fwrite(STDERR, "Run bin/scan-icons --prune to remove them.\n");
}

echo "config/tailor.php now lists {$summary}.\n";

if ($totalNew > 0) {
    $newNames = array_merge(...array_values($added));
    sort($newNames);
    echo "Found {$totalNew} new icon(s): ".implode(', ', $newNames).".\n";
}
